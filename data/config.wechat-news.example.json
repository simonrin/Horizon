    },
    "openbb": {
      "enabled": false,
      "watchlists": [],
      "fetch_filings": false
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": [
        "All"
      ],
      "keywords": [],
      "min_stars": 5,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 4.2,
    "time_window_hours": 24,
    "max_items": 28,
    "category_groups": {
      "domestic_general": {
        "name": "China Domestic News",
        "limit": 14,
        "categories": [
          "domestic"
        ]
      },
      "domestic_business_tech": {
        "name": "China Business and Tech",
        "limit": 8,
        "categories": [
          "domestic-tech",
          "domestic-finance"
        ]
      },
      "international": {
        "name": "International News",
        "limit": 5,
        "categories": [
          "international"
        ]
      },
      "tech_finance": {
        "name": "Global Tech and Finance",
        "limit": 3,
        "categories": [
          "tech",
          "finance"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 1
  }
